{
    "site_package_search_strategy": "pep561",
    "source_directories": [
        {
            "import_root": ".",
            "source": "."
        }
    ],
    "search_path": [
        ".venv/Lib/site-packages",
        ".venv/lib/site-packages"
    ],
    "python_version": "3.10",
    "workers": 4,
    "exclude": [
        ".venv",
        "__pycache__"
    ],
    "ignore_all_errors": false,
    "strict": false
}
